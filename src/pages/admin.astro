<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex" />
        <title>Admin | Isabelle</title>
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap');

            :root {
                --text-main: #171717;
                --bg-main: #f2f1ec;
            }

            @media (prefers-color-scheme: dark) {
                :root {
                    --text-main: #f2f1ec;
                    --bg-main: #18230f;
                }
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: var(--bg-main);
                color: var(--text-main);
                margin: 0;
            }

            #loading-screen {
                position: fixed;
                inset: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                z-index: 1;
                background-color: var(--bg-main);
                transition: opacity 0.3s ease;
            }

            #loading-screen h1 {
                font-family: 'Newsreader', serif;
                font-weight: 500;
                font-size: 2rem;
                font-style: italic;
                margin-bottom: 0.5rem;
            }

            #loading-screen p {
                font-size: 0.875rem;
                opacity: 0.5;
            }
        </style>
    </head>
    <body>
        <div id="loading-screen">
            <h1>Mere Words</h1>
            <p>Loading editor&hellip;</p>
        </div>
        <script is:inline src="https://unpkg.com/decap-cms@^3.1.2/dist/decap-cms.js"></script>
        <script is:inline>
            // Hide loading screen once Decap CMS mounts
            var check = setInterval(function () {
                if (document.getElementById('nc-root')) {
                    var s = document.getElementById('loading-screen');
                    if (s) s.style.display = 'none';
                    clearInterval(check);
                }
            }, 200);
        </script>
    </body>
</html>
