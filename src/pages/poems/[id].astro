---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import PoemPreview from '../../components/PoemPreview.astro';
import Button from '../../components/Button.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugify } from '../../utils/common-utils';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths() {
    const poems = (await getCollection('poems')).sort(sortItemsByDateDesc);
    const poemCount = poems.length;
    return poems.map((poem, index) => ({
        params: { id: poem.id },
        props: {
            poem,
            prevPoem: index + 1 !== poemCount ? poems[index + 1] : null,
            nextPoem: index !== 0 ? poems[index - 1] : null
        }
    }));
}

type Props = {
    poem: CollectionEntry<'poems'>;
    prevPoem: CollectionEntry<'poems'>;
    nextPoem: CollectionEntry<'poems'>;
};

const { href } = Astro.url;
const { poem, prevPoem, nextPoem } = Astro.props;
const { title, description, tags = [], seo } = poem.data;
const categories = poem.data.categories ?? [];
const isHidden = poem.data.hidden ?? false;
const { Content } = await render(poem);
---

<BaseLayout
    title={seo?.title ?? title}
    description={seo?.description ?? description}
    image={seo?.image}
    pageType="article"
    showHeader={false}
    noindex={isHidden}
>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">{title}</h1>
        </header>
        <div class="prose sm:prose-lg max-w-none">
            <Content />
        </div>
        <div class="mt-8 flex flex-wrap items-center justify-between gap-6 text-sm sm:mt-12 sm:text-base">
            <div class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
                {
                    tags.length > 0 &&
                        tags.map((tag) => (
                            <a class="text-main hover:underline" href={`/tags/${slugify(tag)}`}>
                                #{tag}
                            </a>
                        ))
                }
                {
                    categories.length > 0 &&
                        categories.map((cat) => (
                            <a class="text-main hover:underline" href={`/categories/${slugify(cat)}`}>
                                @{cat}
                            </a>
                        ))
                }
            </div>
            <Button class="copy-url-button" aria-label="Copy link" data-url={href} data-tooltip-default="Copy link" data-tooltip-success="Copied">Share</Button>
        </div>
    </article>
    {
        (nextPoem || prevPoem) && (
            <div class="my-16 sm:my-24">
                {nextPoem && (
                    <div class="mb-10 sm:mb-12">
                        <p class="mb-3 font-serif text-sm italic opacity-60">Next</p>
                        <PoemPreview poem={nextPoem} headingLevel="h3" />
                    </div>
                )}
                {prevPoem && (
                    <div class="mb-10 sm:mb-12">
                        <p class="mb-3 font-serif text-sm italic opacity-60">Previous</p>
                        <PoemPreview poem={prevPoem} headingLevel="h3" />
                    </div>
                )}
            </div>
        )
    }
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const copyUrlButton = document.querySelector('.copy-url-button') as HTMLButtonElement;
        copyUrlButton?.addEventListener('click', async () => {
            await copyUrl(copyUrlButton);
        });

        async function copyUrl(button: HTMLButtonElement) {
            let url = button.getAttribute('data-url') || '';
            let label = button.innerText;

            await navigator.clipboard.writeText(url);

            button.innerText = 'Copied';

            setTimeout(() => {
                button.innerText = label;
            }, 2500);
        }
    });
</script>
